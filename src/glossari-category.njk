---
layout: layouts/base.njk
pagination:
  data: glossary.categories
  size: 1
  alias: category
  addAllPagesToCollections: true
permalink: "/glossari/{{ category.slug }}/index.html"
isHome: false
eleventyComputed:
  title: "{{ category.label }} — Γλωσσάρι Ορθοδοντικής | TK Orthodontics"
  description: "{{ category.description }}"
  ogTitle: "{{ category.label }} — Γλωσσάρι Ορθοδοντικής"
  ogDescription: "{{ category.description }}"
  ogType: "website"
  canonical: "{{ glossary.ctx.siteUrl }}/glossari/{{ category.slug }}/"
  robots: "index, follow, max-snippet:-1, max-image-preview:large"
---

{# CollectionPage JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "{{ glossary.ctx.siteUrl }}/glossari/{{ category.slug }}/#collection",
  "name": "{{ category.label }} — {{ glossary.ctx.setName }}",
  "description": "{{ category.description }}",
  "inLanguage": "el-GR",
  "isPartOf": { "@type": "DefinedTermSet", "@id": "{{ glossary.ctx.siteUrl }}/glossari/#set" },
  "hasPart": [
    {%- for t in termsInCategory %}
    {
      "@type": "DefinedTerm",
      "@id": "{{ glossary.ctx.siteUrl }}/glossari/{{ t.slug }}/#term",
      "name": {{ t.term | dump | safe }},
      "url": "{{ glossary.ctx.siteUrl }}/glossari/{{ t.slug }}/"
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>

{% if category.categoryFaqs and category.categoryFaqs.length > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for f in category.categoryFaqs %}
    {
      "@type": "Question",
      "name": {{ f.q | dump | safe }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ f.a | dump | safe }} }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
{% endif %}

<nav class="g-crumbs" aria-label="Διαδρομή">
  <div class="container">
    <ol>
      <li><a href="/">Αρχική</a><span class="g-crumbs__sep" aria-hidden="true">/</span></li>
      <li><a href="/glossari/">Γλωσσάρι</a><span class="g-crumbs__sep" aria-hidden="true">/</span></li>
      <li><span aria-current="page">{{ category.label }}</span></li>
    </ol>
  </div>
</nav>

<section class="page-header">
  <div class="page-header__orb"></div>
  <div class="container">
    <div class="page-header__content">
      <span class="section-label">Γλωσσάρι · {{ termsInCategory.length }} όρ{% if termsInCategory.length == 1 %}ος{% else %}οι{% endif %}</span>
      <h1 class="page-header__title">{{ category.label }}</h1>
      {% if category.pillarIntro %}<p class="page-header__desc">{{ category.pillarIntro }}</p>{% endif %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="glossari-grid">
      {% for t in termsInCategory %}
      <a href="/glossari/{{ t.slug }}/" class="glossari-card">
        <span class="glossari-card__cat">{{ category.label }}</span>
        <h2 class="glossari-card__title">{{ t.term }}</h2>
        <p class="glossari-card__excerpt">{{ t.oneLineAnswer or (t.definition | firstSentence) }}</p>
        <span class="glossari-card__cta">Διαβάστε ορισμό →</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

{% if category.categoryFaqs and category.categoryFaqs.length > 0 %}
<section id="faqs" class="section section--alt">
  <div class="container" style="max-width: 820px;">
    <h2 style="margin-bottom: 1.5rem;">Συχνές ερωτήσεις: {{ category.label }}</h2>
    <div class="g-faq__list">
      {% for f in category.categoryFaqs %}
      <details class="g-faq__item"{% if loop.first %} open{% endif %}>
        <summary>
          <span class="faq__q">{{ f.q }}</span>
          <span class="g-faq__icon" aria-hidden="true">+</span>
        </summary>
        <div class="faq__a"><p>{{ f.a }}</p></div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<style>
  .glossari-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .glossari-card { display: block; background: var(--c-surface); border: 1px solid var(--c-border); padding: 1.5rem; border-radius: var(--radius); text-decoration: none; color: var(--c-text); transition: border-color var(--t-fast) var(--ease), transform var(--t-fast) var(--ease); }
  .glossari-card:hover { border-color: var(--c-accent); transform: translateY(-2px); }
  .glossari-card__cat { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.12em; color: var(--c-accent); display: inline-block; margin-bottom: 0.75rem; font-weight: 600; }
  .glossari-card__title { font-family: var(--f-heading); font-size: 1.2rem; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.3; }
  .glossari-card__excerpt { color: var(--c-text-muted); font-size: 0.92rem; line-height: 1.55; margin-bottom: 0.75rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .glossari-card__cta { color: var(--c-accent); font-size: 0.88rem; font-weight: 600; }
  .g-crumbs { padding: 1rem 0; background: var(--c-bg-alt); border-bottom: 1px solid var(--c-border); font-size: var(--fs-small); }
  .g-crumbs ol { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; }
  .g-crumbs li { display: flex; align-items: center; gap: 0.4rem; }
  .g-crumbs a { color: var(--c-text-muted); }
  .g-crumbs a:hover { color: var(--c-accent); }
  .g-crumbs span[aria-current] { color: var(--c-text); }
  .g-crumbs__sep { color: var(--c-border); }
  .g-faq__list { border-top: 1px solid var(--c-border); }
  .g-faq__item { border-bottom: 1px solid var(--c-border); }
  .g-faq__item summary { list-style: none; cursor: pointer; padding: 1.25rem 0; display: flex; align-items: center; justify-content: space-between; gap: 1rem; font-weight: 600; color: var(--c-text); }
  .g-faq__item summary::-webkit-details-marker { display: none; }
  .faq__q { font-size: 1.05rem; line-height: 1.4; }
  .g-faq__icon { flex-shrink: 0; width: 32px; height: 32px; border: 1px solid var(--c-border); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--c-accent); font-weight: 400; transition: transform var(--t-fast) var(--ease); }
  .g-faq__item[open] .g-faq__icon { transform: rotate(45deg); }
  .faq__a { padding: 0 0 1.25rem; max-width: 75ch; }
  .faq__a p { color: var(--c-text-muted); margin: 0; }
</style>
