{# Glossary term article — Nunjucks port of glossari/src/components/GlossaryArticle.astro.

   Expects in scope:
     - term            the GlossaryTerm
     - author          resolved author object
     - category        resolved category object
     - sameCategory    array of sibling terms in the same category

   The base.njk layout handles JSON-LD + OG/canonical/robots/hreflang via the
   front-matter on the calling template. This partial only renders the body.
#}

{# Build TOC entries based on which sections will render #}
{% set tocEntries = [
  { id: 'pou-xrisimopoieitai', label: 'Πού χρησιμοποιείται' },
  { id: 'pleonektimata', label: 'Πλεονεκτήματα' },
  { id: 'lathos', label: 'Συνηθισμένα λάθη' }
] %}
{% if term.steps and term.steps.length > 0 %}{% set tocEntries = tocEntries.concat([{ id: 'pos-ginete', label: 'Πώς γίνεται (βήματα)' }]) %}{% endif %}
{% if term.cost %}{% set tocEntries = tocEntries.concat([{ id: 'kostos', label: 'Ενδεικτικό κόστος' }]) %}{% endif %}
{% if term.whenItMakesSense %}{% set tocEntries = tocEntries.concat([{ id: 'pote-aksizei', label: 'Πότε αξίζει' }]) %}{% endif %}
{% if term.comparisons and term.comparisons.length > 0 %}{% set tocEntries = tocEntries.concat([{ id: 'sygkriseis', label: 'Συγκρίσεις' }]) %}{% endif %}
{% if term.sources and term.sources.length > 0 %}{% set tocEntries = tocEntries.concat([{ id: 'piges', label: 'Πηγές' }]) %}{% endif %}
{% set tocEntries = tocEntries.concat([{ id: 'faqs', label: 'Συχνές ερωτήσεις' }]) %}

<article class="g-article">

  {# Dark page-header — provides the dark band behind the fixed nav so the
     nav's white text is readable. Contains breadcrumb + hero content. #}
  <header class="page-header g-page-header">
    <div class="page-header__orb"></div>
    <div class="container">

      <nav class="g-crumbs" aria-label="Διαδρομή">
        <ol>
          <li><a href="/">Αρχική</a><span class="g-crumbs__sep" aria-hidden="true">/</span></li>
          <li><a href="/glossari/">Γλωσσάρι</a><span class="g-crumbs__sep" aria-hidden="true">/</span></li>
          <li><a href="/glossari/{{ category.slug }}/">{{ category.label }}</a><span class="g-crumbs__sep" aria-hidden="true">/</span></li>
          <li><span aria-current="page">{{ term.term }}</span></li>
        </ol>
      </nav>

      <a class="g-hero__eyebrow" href="/glossari/{{ category.slug }}/">{{ category.label }}</a>
      <h1 class="g-hero__h1">{{ term.h1 }}</h1>

      <aside class="g-tldr" aria-label="Σύντομη απάντηση">
        <span class="g-tldr__label">Με μια ματιά</span>
        <p class="g-tldr__text faq__a">{{ term.oneLineAnswer or term.definition }}</p>
      </aside>

      <div class="g-byline">
        <span class="g-byline__by">Σύνταξη:</span>
        {% if author.url %}<a class="g-byline__author" href="{{ author.url }}">{{ author.name }}</a>{% else %}<span class="g-byline__author">{{ author.name }}</span>{% endif %}
        <span class="g-byline__sep">·</span>
        <span class="g-byline__role">{{ author.role }}</span>
        <span class="g-byline__sep">·</span>
        <span class="g-byline__dates">
          Δημοσιεύτηκε <time datetime="{{ term.publishedAt }}">{{ term.publishedAt }}</time>{% if term.publishedAt != term.updatedAt %} · Ενημερώθηκε <time datetime="{{ term.updatedAt }}">{{ term.updatedAt }}</time>{% endif %}
        </span>
        {% if term.reviewedBy %}
        <span class="g-byline__sep">·</span>
        <span class="g-byline__reviewed">Έλεγχος: {{ term.reviewedBy.name }} ({{ term.reviewedBy.credentials }})</span>
        {% endif %}
      </div>
    </div>
  </header>

  {# Hero image #}
  {% if term.heroImage %}
  <figure class="g-hero-image">
    <img src="{{ term.heroImage.src }}" alt="{{ term.heroImage.alt }}" width="{{ term.heroImage.width }}" height="{{ term.heroImage.height }}" loading="eager" decoding="async" fetchpriority="high">
    {% if term.heroImage.caption or term.heroImage.credit %}
    <figcaption>{{ term.heroImage.caption }}{% if term.heroImage.credit %} <span class="g-hero-image__credit">— {{ term.heroImage.credit }}</span>{% endif %}</figcaption>
    {% endif %}
  </figure>
  {% endif %}

  <div class="container g-body">
    <div class="g-main">

      {# TOC #}
      {% if tocEntries.length > 3 %}
      <nav class="g-toc" aria-label="Περιεχόμενα">
        <span class="g-toc__label">Σε αυτή τη σελίδα</span>
        <ol>
          {% for e in tocEntries %}<li><a href="#{{ e.id }}">{{ e.label }}</a></li>{% endfor %}
        </ol>
      </nav>
      {% endif %}

      <section class="g-prose">
        <h2 id="pou-xrisimopoieitai">Πού χρησιμοποιείται</h2>
        <p>{{ term.whereUsed }}</p>

        <h2 id="pleonektimata">Πλεονεκτήματα</h2>
        <ul>
          {% for a in term.advantages %}<li>{{ a }}</li>{% endfor %}
        </ul>

        <h2 id="lathos">Συνηθισμένα λάθη και τι να προσέξετε</h2>
        <ul>
          {% for m in term.mistakes %}<li>{{ m }}</li>{% endfor %}
        </ul>

        {% if term.images and term.images.length > 0 %}
        <div class="g-inline-images">
          {% for img in term.images %}
          <figure>
            <img src="{{ img.src }}" alt="{{ img.alt }}" width="{{ img.width }}" height="{{ img.height }}" loading="lazy" decoding="async">
            {% if img.caption %}<figcaption>{{ img.caption }}</figcaption>{% endif %}
          </figure>
          {% endfor %}
        </div>
        {% endif %}

        {% if term.steps and term.steps.length > 0 %}
        <h2 id="pos-ginete">Πώς γίνεται — βήμα προς βήμα</h2>
        <ol class="g-steps">
          {% for s in term.steps %}
          <li class="g-steps__item">
            <span class="g-steps__num">{{ loop.index }}</span>
            <div class="g-steps__body">
              <strong class="g-steps__name">{{ s.name }}</strong>
              <p>{{ s.text }}</p>
              {% if s.duration %}<span class="g-steps__duration" aria-label="Διάρκεια">{{ s.duration }}</span>{% endif %}
            </div>
          </li>
          {% endfor %}
        </ol>
        {% endif %}

        {% if term.cost %}
        <h2 id="kostos">Ενδεικτικό κόστος</h2>
        <p>{{ term.cost }}</p>
        <p class="g-muted" style="font-size:0.85rem;">Οι τιμές είναι ενδεικτικές και εξαρτώνται από την περίπτωση και την έκταση της θεραπείας.{% if term.priceAsOf %} Τιμές με αναφορά: <time datetime="{{ term.priceAsOf }}">{{ term.priceAsOf }}</time>.{% endif %}</p>
        {% endif %}

        {% if term.whenItMakesSense %}
        <h2 id="pote-aksizei">Πότε αξίζει</h2>
        <p>{{ term.whenItMakesSense }}</p>
        {% endif %}

        {% if term.comparisons and term.comparisons.length > 0 %}
        <h2 id="sygkriseis">Συγκρίσεις</h2>
        {% for c in term.comparisons %}
        <section class="g-cmp" id="sygkrisi-{{ loop.index0 }}">
          <h3>{{ term.term }} vs {{ c.against }}</h3>
          {% if c.verdict %}<p class="g-cmp__verdict">{{ c.verdict }}</p>{% endif %}
          <div class="g-cmp__scroll">
            <table>
              <thead>
                <tr><th scope="col">Χαρακτηριστικό</th><th scope="col">{{ term.term }}</th><th scope="col">{{ c.against }}</th></tr>
              </thead>
              <tbody>
                {% for r in c.rows %}
                <tr><th scope="row">{{ r.feature }}</th><td>{{ r.us }}</td><td>{{ r.them }}</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>
        {% endfor %}
        {% endif %}

        {% if term.sources and term.sources.length > 0 %}
        <h2 id="piges">Πηγές & Παραπομπές</h2>
        <ul class="g-sources">
          {% for s in term.sources %}
          <li class="g-sources__item">
            <span class="g-sources__type g-sources__type--{{ s.type }}">{% if s.type == 'standard' %}Πρότυπο{% elif s.type == 'regulation' %}Κανονισμός{% elif s.type == 'study' %}Μελέτη{% elif s.type == 'gov' %}Κρατικός φορέας{% elif s.type == 'book' %}Βιβλίο{% else %}Άρθρο{% endif %}</span>
            {% if s.url %}<a href="{{ s.url }}" rel="noopener noreferrer" target="_blank">{{ s.title }}</a>{% else %}<span>{{ s.title }}</span>{% endif %}
            {% if s.issuer %}<span class="g-sources__issuer"> — {{ s.issuer }}</span>{% endif %}
            {% if s.year %}<span class="g-sources__year"> ({{ s.year }})</span>{% endif %}
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </section>
    </div>

    <aside class="g-aside">
      <div class="g-aside-card">
        <span class="g-aside-card__label">Κατηγορία</span>
        <p class="g-aside-card__category"><a href="/glossari/{{ category.slug }}/">{{ category.label }}</a></p>
      </div>

      <div class="g-aside-card g-aside-cta">
        <h3>Χρειάζεστε ορθοδοντική;</h3>
        <p>Δωρεάν αρχική εκτίμηση από τον Dr. Τσιότρα — χωρίς δέσμευση.</p>
        <a href="/contact.html" class="btn btn--primary" style="width:100%;">Ζητήστε Ραντεβού</a>
      </div>

      {% if sameCategory.length > 0 %}
      <div class="g-aside-card">
        <h3>Στην ίδια κατηγορία</h3>
        <ul class="g-aside-card__list">
          {% for t in sameCategory %}<li><a href="/glossari/{{ t.slug }}/">{{ t.term }}</a></li>{% endfor %}
        </ul>
      </div>
      {% endif %}
    </aside>
  </div>

  {# FAQs #}
  <section id="faqs" class="section section--alt">
    <div class="container" style="max-width: 820px;">
      <h2 style="margin-bottom: 1.5rem;">Συχνές ερωτήσεις</h2>
      <div class="g-faq__list">
        {% for f in term.faqs %}
        <details class="g-faq__item"{% if loop.first %} open{% endif %}>
          <summary>
            <span class="faq__q">{{ f.q }}</span>
            <span class="g-faq__icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq__a"><p>{{ f.a }}</p></div>
        </details>
        {% endfor %}
      </div>
    </div>
  </section>

  {# Citation block #}
  <div class="container">
    <section class="g-citation" aria-labelledby="cite-{{ term.slug }}">
      <h3 id="cite-{{ term.slug }}">Παραπομπή σε αυτό τον όρο</h3>
      <p class="g-citation__lead">Χρησιμοποιήστε μία από τις παρακάτω μορφές για να αναφέρετε αυτό τον ορισμό.</p>
      {% set termUrl = site.url + '/glossari/' + term.slug + '/' %}
      {% set year = term.updatedAt.split('-')[0] %}
      {% set apa = author.name + ' (' + year + '). ' + term.term + '. ' + site.name + '. Ανακτήθηκε από ' + termUrl %}
      {% set htmlCite = '<a href="' + termUrl + '">' + term.term + '</a> — ' + site.name %}
      {% set md = '[' + term.term + '](' + termUrl + ') — ' + site.name %}
      <div class="g-citation__row">
        <span class="g-citation__label">APA</span>
        <code class="g-citation__code">{{ apa }}</code>
        <button class="g-citation__btn" type="button" data-citation-copy="{{ apa }}" aria-label="Αντιγραφή APA">Αντιγραφή</button>
      </div>
      <div class="g-citation__row">
        <span class="g-citation__label">HTML</span>
        <code class="g-citation__code">{{ htmlCite }}</code>
        <button class="g-citation__btn" type="button" data-citation-copy="{{ htmlCite }}" aria-label="Αντιγραφή HTML">Αντιγραφή</button>
      </div>
      <div class="g-citation__row">
        <span class="g-citation__label">Markdown</span>
        <code class="g-citation__code">{{ md }}</code>
        <button class="g-citation__btn" type="button" data-citation-copy="{{ md }}" aria-label="Αντιγραφή Markdown">Αντιγραφή</button>
      </div>
      <p class="g-citation__meta">
        <span>Δημοσιεύτηκε: <time datetime="{{ term.publishedAt }}">{{ term.publishedAt }}</time></span>
        <span> · </span>
        <span>Τελευταία ενημέρωση: <time datetime="{{ term.updatedAt }}">{{ term.updatedAt }}</time></span>
      </p>
    </section>
  </div>

</article>

<script>
  document.querySelectorAll('[data-citation-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const value = btn.dataset.citationCopy || '';
      try {
        await navigator.clipboard.writeText(value);
        const original = btn.textContent;
        btn.textContent = 'Αντιγράφηκε!';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {}
    });
  });
</script>

<style>
  .g-article { font-family: var(--f-body); color: var(--c-text); }

  /* Dark page-header — provides the dark band behind the fixed nav so its
     white text is readable. Matches tk4a's existing .page-header pattern. */
  .g-page-header { padding-bottom: clamp(2.5rem, 5vw, 4rem); }

  .g-crumbs { font-size: var(--fs-small); margin-bottom: 1.5rem; }
  .g-crumbs ol { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; }
  .g-crumbs li { display: flex; align-items: center; gap: 0.4rem; }
  .g-crumbs a { color: rgba(255,255,255,0.55); }
  .g-crumbs a:hover { color: var(--c-accent); }
  .g-crumbs span[aria-current] { color: var(--c-text-light); }
  .g-crumbs__sep { color: rgba(255,255,255,0.2); }

  .g-hero__eyebrow { font-family: var(--f-heading); color: var(--c-accent); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.14em; text-decoration: none; font-weight: 600; }
  .g-hero__eyebrow:hover { text-decoration: underline; }
  .g-hero__h1 { font-family: var(--f-display); font-size: clamp(1.75rem, 3vw, 2.4rem); font-weight: 600; line-height: 1.2; margin: 0.6rem 0 1.5rem; max-width: 28ch; color: var(--c-text-light); }

  /* TLDR card on dark bg — translucent surface + accent border */
  .g-tldr { margin-top: 1.5rem; padding: 1.25rem 1.5rem; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-left: 3px solid var(--c-accent); border-radius: var(--radius); max-width: 72ch; }
  .g-tldr__label { display: inline-block; font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.14em; color: var(--c-accent); font-weight: 600; margin-bottom: 0.6rem; }
  .g-tldr__text { margin: 0; font-size: 1.05rem; line-height: 1.55; color: rgba(255,255,255,0.92); }

  .g-byline { margin-top: 1.5rem; font-size: var(--fs-small); color: rgba(255,255,255,0.55); line-height: 1.6; }
  .g-byline__by { margin-right: 0.25rem; }
  .g-byline__author { color: var(--c-text-light); font-weight: 600; text-decoration: none; }
  .g-byline__author:hover { color: var(--c-accent); }
  .g-byline__sep { color: rgba(255,255,255,0.25); margin: 0 0.4rem; }

  .g-hero-image { margin: 2rem auto; max-width: 1100px; padding: 0 var(--s-container, 1rem); }
  .g-hero-image img { width: 100%; height: auto; display: block; border-radius: var(--radius-lg); box-shadow: var(--shadow); }
  .g-hero-image figcaption { padding: 0.7rem 0 0; font-size: var(--fs-small); color: var(--c-text-muted); text-align: center; }

  .g-body { display: grid; grid-template-columns: 1fr 280px; gap: 3rem; padding: 3rem 0; align-items: start; }
  .g-body .container { padding: 0; }

  .g-toc { background: var(--c-bg-alt); border: 1px solid var(--c-border); padding: 1.25rem; margin-bottom: 2rem; border-radius: var(--radius); }
  .g-toc__label { display: block; font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.12em; color: var(--c-text-muted); margin-bottom: 0.6rem; font-weight: 600; }
  .g-toc ol { list-style: decimal; margin: 0; padding-left: 1.2rem; columns: 2; column-gap: 1.5rem; }
  .g-toc li { margin: 0.25rem 0; }
  .g-toc a { color: var(--c-text); font-size: var(--fs-small); }
  .g-toc a:hover { color: var(--c-accent); }

  .g-prose h2 { font-family: var(--f-heading); font-size: clamp(1.25rem, 1.8vw, 1.5rem); margin-top: 2.5rem; margin-bottom: 1rem; scroll-margin-top: 100px; color: var(--c-text); line-height: 1.25; }
  .g-prose h2:first-of-type { margin-top: 0; }
  .g-prose h3 { font-family: var(--f-heading); font-size: clamp(1.05rem, 1.4vw, 1.2rem); margin-top: 1.5rem; margin-bottom: 0.75rem; color: var(--c-text); line-height: 1.3; }
  .g-prose p { margin-bottom: 1rem; color: var(--c-text); max-width: 65ch; line-height: var(--lh-body); }

  /* Brand-coloured bullet points — replaces default browser markers */
  .g-prose ul { list-style: none; padding-left: 0; margin-bottom: 1rem; }
  .g-prose ul li {
    position: relative;
    padding-left: 1.6rem;
    margin-bottom: 0.55rem;
    line-height: var(--lh-body);
  }
  .g-prose ul li::before {
    content: '';
    position: absolute;
    left: 0.35rem;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: 0 0 0 3px var(--c-accent-subtle);
  }
  /* Ordered lists keep numbers but tint them green */
  .g-prose ol { padding-left: 1.5rem; margin-bottom: 1rem; }
  .g-prose ol li { margin-bottom: 0.55rem; line-height: var(--lh-body); }
  .g-prose ol li::marker { color: var(--c-accent); font-weight: 700; }
  .g-muted { color: var(--c-text-muted); }

  /* Inline images (term.images[] — rendered between sections) */
  .g-inline-images { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; margin: 2rem 0; max-width: none; }
  .g-inline-images figure { margin: 0; }
  .g-inline-images img { width: 100%; height: auto; display: block; border-radius: var(--radius); box-shadow: var(--shadow-sm); }
  .g-inline-images figcaption { font-size: var(--fs-small); color: var(--c-text-muted); padding-top: 0.5rem; text-align: center; }

  .g-steps { list-style: none; padding: 0; display: grid; gap: 1rem; }
  .g-steps__item { display: grid; grid-template-columns: auto 1fr; gap: 1.25rem; padding: 1.5rem; background: var(--c-bg-alt); border: 1px solid var(--c-border); border-radius: var(--radius); }
  .g-steps__num { width: 36px; height: 36px; border-radius: 50%; background: var(--c-accent); color: var(--c-bg-dark); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1rem; flex-shrink: 0; }
  .g-steps__body strong { display: block; margin-bottom: 0.4rem; font-size: 1.1rem; }
  .g-steps__body p { margin: 0; }
  .g-steps__duration { display: inline-block; margin-top: 0.5rem; font-size: var(--fs-xs); color: var(--c-text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }

  .g-cmp { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--c-border); }
  .g-cmp h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .g-cmp__verdict { color: var(--c-text-muted); font-style: italic; max-width: 65ch; margin-bottom: 1rem; }
  .g-cmp__scroll { overflow-x: auto; }
  .g-cmp table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .g-cmp th, .g-cmp td { padding: 0.85rem 1rem; text-align: left; border-bottom: 1px solid var(--c-border); vertical-align: top; }
  .g-cmp thead th { background: var(--c-bg-alt); font-weight: 600; color: var(--c-text); }
  .g-cmp tbody th { font-weight: 500; color: var(--c-text-muted); background: var(--c-bg); }
  .g-cmp tbody td { color: var(--c-text); }

  .g-sources { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--c-border); }
  .g-sources__item { padding: 0.85rem 0; border-bottom: 1px solid var(--c-border); font-size: var(--fs-small); display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem; }
  .g-sources__type { display: inline-block; padding: 0.18rem 0.6rem; font-size: var(--fs-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; background: var(--c-bg-alt); border: 1px solid var(--c-border); border-radius: var(--radius-pill); }
  .g-sources__type--standard { color: var(--c-accent); }
  .g-sources__type--regulation { color: #b45309; }
  .g-sources__type--gov { color: #1f5e8c; }
  .g-sources__issuer, .g-sources__year { color: var(--c-text-muted); }

  .g-aside { position: sticky; top: 100px; display: grid; gap: 1rem; }
  .g-aside-card { background: var(--c-bg-alt); border: 1px solid var(--c-border); padding: 1.5rem; border-radius: var(--radius); }
  .g-aside-card h3 { font-size: 1rem; margin-bottom: 0.75rem; }
  .g-aside-card p { color: var(--c-text-muted); font-size: 0.92rem; margin-bottom: 0.75rem; }
  .g-aside-card__label { display: block; font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.12em; color: var(--c-text-muted); margin-bottom: 0.6rem; font-weight: 600; }
  .g-aside-card__category { font-size: 1.05rem; color: var(--c-accent); font-weight: 600; margin: 0; }
  .g-aside-card__category a { color: inherit; text-decoration: none; }
  .g-aside-card__category a:hover { text-decoration: underline; }
  .g-aside-card__list { list-style: none; margin: 0; padding: 0; }
  .g-aside-card__list li { margin: 0; padding: 0.6rem 0; border-bottom: 1px solid var(--c-border); font-size: 0.95rem; }
  .g-aside-card__list li:last-child { border-bottom: none; }
  .g-aside-card__list a { color: var(--c-text); }
  .g-aside-card__list a:hover { color: var(--c-accent); }

  .g-aside-cta { background: var(--c-bg-dark); color: var(--c-text-light); }
