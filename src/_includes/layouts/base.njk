  :root{--c-bg:#FAFAFA;--c-bg-alt:#F0F0F0;--c-bg-dark:#111110;--c-bg-dark-alt:#141312;--c-surface:#FFF;--c-text:#1A1A1A;--c-text-light:#F5F5F5;--c-text-muted:#5C5C66;--c-accent:#3ECDA5;--c-accent-hover:#35B894;--c-accent-dark:#2DA382;--c-accent-glow:rgba(62,205,165,0.15);--c-accent-subtle:rgba(62,205,165,0.08);--c-border:rgba(0,0,0,0.07);--c-border-light:rgba(255,255,255,0.1);--c-glass:rgba(255,255,255,0.72);--c-glass-dark:rgba(17,17,16,0.88);--c-bg-warm:#F4F3EF;--f-display:'Source Serif 4',Georgia,serif;--f-heading:'IBM Plex Sans',system-ui,sans-serif;--f-body:'IBM Plex Sans',system-ui,sans-serif;--fs-display:clamp(2rem,3.8vw,3.5rem);--fs-h1:clamp(2rem,4.5vw,3.8rem);--fs-h2:clamp(1.6rem,3.2vw,2.6rem);--fs-h3:clamp(1.15rem,1.8vw,1.45rem);--fs-body:clamp(0.95rem,1.1vw,1.1rem);--fs-small:clamp(0.8rem,0.9vw,0.9rem);--fs-xs:clamp(0.75rem,0.8vw,0.8rem);--lh-tight:1.1;--lh-snug:1.3;--lh-body:1.65;--s-section:clamp(5rem,12vw,9rem);--s-container:min(calc(100% - 48px),1200px);--s-gap:clamp(1rem,2vw,2rem);--radius:14px;--radius-sm:8px;--radius-lg:24px;--radius-pill:100px;--shadow-sm:0 2px 8px rgba(0,0,0,0.04);--shadow:0 4px 24px rgba(0,0,0,0.06);--shadow-lg:0 16px 56px rgba(0,0,0,0.1);--shadow-accent:0 8px 32px var(--c-accent-glow);--ease:cubic-bezier(0.4,0,0.2,1);--ease-out:cubic-bezier(0,0,0.2,1);--ease-spring:cubic-bezier(0.34,1.56,0.64,1);--t-fast:0.2s;--t-base:0.35s;--t-slow:0.6s;--t-reveal:0.8s}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;font-size:16px;overflow-x:hidden}
  body{font-family:var(--f-body);font-size:var(--fs-body);line-height:var(--lh-body);color:var(--c-text);background:var(--c-bg);overflow-x:hidden;-webkit-font-smoothing:antialiased}
  img,svg{display:block;max-width:100%;height:auto}picture{display:block}
  a{color:inherit;text-decoration:none}button{font:inherit;cursor:pointer;border:none;background:none}
  h1,h2,h3,h4,h5,h6{font-family:var(--f-heading);font-weight:700;line-height:var(--lh-tight);letter-spacing:-0.02em}
  .page-wrapper{opacity:0;transform:translateY(12px);transition:opacity var(--t-slow) var(--ease),transform var(--t-slow) var(--ease)}
  .page-wrapper.is-loaded{opacity:1;transform:translateY(0)}
  .grain{position:fixed;inset:0;pointer-events:none;z-index:10000;opacity:0.028}
  .container{width:var(--s-container);margin:0 auto}
  .nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.2rem 0}
  .nav__inner{width:100%;padding:0 2rem;display:flex;align-items:center;justify-content:space-between}
  .nav__logo{font-family:var(--f-heading);font-size:1.25rem;font-weight:700;letter-spacing:-0.04em;display:flex;align-items:center;gap:0.6rem;flex-shrink:0}
  .nav__links{display:flex;align-items:center;gap:2.2rem;flex-wrap:nowrap;white-space:nowrap}
  .nav__link{font-family:var(--f-heading);font-size:var(--fs-small);font-weight:500;position:relative;padding:0.2rem 0}
  .nav--dark .nav__link{color:var(--c-text-light)}.nav--dark .nav__logo{color:var(--c-text-light)}
  .nav__toggle{display:none;flex-direction:column;gap:5px;width:28px;cursor:pointer;z-index:1001}
  .nav__toggle span{width:100%;height:2px;background:currentColor;border-radius:2px}
  .hero{position:relative;min-height:90vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:linear-gradient(160deg,#0f1418 0%,#12181d 50%,#0f1418 100%);color:var(--c-text-light)}
  .hero__inner{position:relative;z-index:3;width:var(--s-container);margin:0 auto;display:grid;grid-template-columns:1.1fr 0.9fr;gap:56px;align-items:center}
  .hero__content{max-width:640px;position:relative;z-index:3}
  .hero__title{font-family:var(--f-display);font-size:var(--fs-display);font-weight:500;line-height:1.15;margin-bottom:20px;max-width:22ch;color:rgba(255,255,255,0.92)}
  .hero__photo{position:relative;z-index:10;border-radius:22px;overflow:hidden;aspect-ratio:4/5;max-width:500px;max-height:540px;box-shadow:0 20px 60px rgba(0,0,0,0.35)}
  .hero__photo-img{width:100%;height:100%;object-fit:cover;object-position:60% center;display:block}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.9rem 2rem;font-family:var(--f-heading);font-size:var(--fs-small);font-weight:600;letter-spacing:0.02em;border-radius:var(--radius-pill);border:none;cursor:pointer}
  .btn--primary{background:var(--c-accent);color:#06221A}
  .btn--sm{padding:0.6rem 1.4rem;font-size:var(--fs-xs)}
  .section-label{display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--f-heading);font-size:var(--fs-xs);font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:var(--c-accent);margin-bottom:1rem}
  .reveal,.reveal--left,.reveal--right,.reveal--scale{opacity:0}
  .section{padding:var(--s-section) 0}.section--dark{background:var(--c-bg-dark);color:var(--c-text-light)}
  .section--alt{background:var(--c-bg-warm)}
  .page-header{position:relative;background:var(--c-bg-dark);color:var(--c-text-light);padding:clamp(7rem,14vw,10rem) 0 clamp(3rem,6vw,5rem);overflow:hidden}
  @media(max-width:1024px){.hero__inner{grid-template-columns:1fr;padding:100px 0 0;gap:0}.hero__photo{margin-right:0;transform:none;max-width:280px;max-height:320px;aspect-ratio:3/4;margin:2rem auto 0}.nav__links{display:none}}
  @media(max-width:768px){.nav__toggle{display:flex}}
